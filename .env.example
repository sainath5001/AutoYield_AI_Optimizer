# Optional reference: copy lines into the right file — never commit real secrets.
#
# Frontend-only → copy into frontend/.env.local
# Backend-only  → copy into backend/.env

# --- Frontend (frontend/.env.local) — WalletConnect / RainbowKit needs this here only ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- Backend (backend/.env) — not used for WalletConnect ---
PORT=4000
LIFI_API_KEY=
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
