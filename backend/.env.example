PORT=4000

# WalletConnect / NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID live in frontend/.env.local only.

# Optional — higher rate limits on Earn + li.quest (Partner Portal).
LIFI_API_KEY=

# Optional — shown on Composer quotes (tracking label).
# LIFI_INTEGRATOR=AutoYield_AI_Optimizer

# OpenAI — server only (never expose to the frontend). Used for POST /api/recommendation.
OPENAI_API_KEY=
# Optional model override (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
